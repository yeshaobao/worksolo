<Window
    x:Class="WorkClosure.Dialogs.TaskEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <Grid x:Name="RootGrid" Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            x:Name="EditorScrollViewer"
            Grid.Row="0"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled">
            <StackPanel Padding="0,4,0,0" Spacing="16">
                <TextBlock Text="{Binding Editor.HeaderText}" Style="{StaticResource SectionTitleTextStyle}" />

                <Border Style="{StaticResource SurfacePanelCompactStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Name="BasicSectionAnchor"
                            Text="基本信息"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AppTitleBrush}" />

                        <TextBox
                            Header="标题"
                            Text="{Binding Editor.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                Grid.Column="0"
                                Header="项目"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding Editor.ProjectOptions}"
                                SelectedValuePath="Id"
                                SelectedValue="{Binding Editor.SelectedProjectId, Mode=TwoWay}" />

                            <ComboBox
                                Grid.Column="1"
                                Header="主状态"
                                DisplayMemberPath="Label"
                                ItemsSource="{Binding Editor.StatusOptions}"
                                SelectedValuePath="Value"
                                SelectedValue="{Binding Editor.SelectedStatusValue, Mode=TwoWay}" />
                        </Grid>

                        <ComboBox
                            Header="异常标记"
                            DisplayMemberPath="Label"
                            ItemsSource="{Binding Editor.AnomalyOptions}"
                            SelectedValuePath="Value"
                            SelectedValue="{Binding Editor.SelectedAnomalyValue, Mode=TwoWay}" />

                        <Border Style="{StaticResource SurfacePanelCompactStyle}">
                            <StackPanel Spacing="10">
                                <CheckBox
                                    Content="设置预计完成时间"
                                    IsChecked="{Binding Editor.HasDueDate, Mode=TwoWay}" />
                                <TextBlock
                                    Text="{Binding Editor.DueDateStatusText}"
                                    Style="{StaticResource CaptionTextStyle}" />
                                <CalendarDatePicker
                                    Visibility="{Binding Editor.DueDateEditorVisibility}"
                                    Date="{Binding Editor.DueDate, Mode=TwoWay}"
                                    MinDate="{Binding Editor.MinimumDueDate}"
                                    PlaceholderText="未设置" />
                            </StackPanel>
                        </Border>

                        <TextBox
                            Header="异常说明 / 背景"
                            AcceptsReturn="True"
                            MinHeight="96"
                            Text="{Binding Editor.AnomalyNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Border Style="{StaticResource SurfacePanelCompactStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock FontWeight="SemiBold" Text="时间与摘要" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Editor.CreatedText}" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Editor.StartedText}" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Editor.CompletedText}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding SelectedTask.LatestProgressSummary}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding SelectedTask.LatestIssueSummary}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding SelectedTask.LatestNextStepSummary}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfacePanelCompactStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            x:Name="ProgressSectionAnchor"
                            Text="进展记录"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource AppTitleBrush}" />

                        <CalendarDatePicker Header="记录日期" Date="{Binding NewProgressDate, Mode=TwoWay}" />

                        <TextBlock
                            Text="同一天只保留一条进展记录，再次保存会覆盖当天内容。"
                            Style="{StaticResource CaptionTextStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="18">
                            <CheckBox
                                VerticalAlignment="Center"
                                Content="需继续跟进"
                                IsChecked="{Binding NewNeedFollowUp, Mode=TwoWay}" />
                            <CheckBox
                                VerticalAlignment="Center"
                                Content="关键节点"
                                IsChecked="{Binding NewIsKeyMilestone, Mode=TwoWay}" />
                        </StackPanel>

                        <TextBox
                            Header="今日进展"
                            AcceptsReturn="True"
                            MinHeight="84"
                            Text="{Binding NewProgressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox
                            Header="当前问题"
                            AcceptsReturn="True"
                            MinHeight="70"
                            Text="{Binding NewIssueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox
                            Header="下一步"
                            AcceptsReturn="True"
                            MinHeight="70"
                            Text="{Binding NewNextStepText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <StackPanel Spacing="10">
                    <TextBlock Text="历史时间线" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock
                        Visibility="{Binding EmptyProgressVisibility}"
                        Text="当前还没有进展记录。"
                        Style="{StaticResource CaptionTextStyle}" />

                    <ItemsControl Visibility="{Binding ProgressEntriesVisibility}" ItemsSource="{Binding ProgressEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="model:TaskProgressEntry">
                                <Border Margin="0,0,0,10" Style="{StaticResource SurfacePanelCompactStyle}">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock FontWeight="SemiBold" Text="{Binding EntryDateText}" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Foreground="{ThemeResource WarningBrush}"
                                                Text="{Binding FollowUpText}" />
                                            <TextBlock
                                                Grid.Column="2"
                                                Foreground="{ThemeResource AppAccentStrongBrush}"
                                                Text="{Binding MilestoneText}" />
                                            <Button
                                                Grid.Column="3"
                                                Content="编辑"
                                                Click="EditProgressButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Tag="{Binding}" />
                                            <Button
                                                Grid.Column="4"
                                                Content="删除"
                                                Click="DeleteProgressButton_Click"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Tag="{Binding}" />
                                        </Grid>

                                        <TextBlock Text="{Binding ProgressText}" TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding IssueText}"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Style="{StaticResource CaptionTextStyle}"
                                            Text="{Binding NextStepText}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" ColumnSpacing="12" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Content="关闭"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="CancelButton_Click" />
            <Button
                Grid.Column="1"
                Content="保存"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="SaveButton_Click" />
            <Button
                Grid.Column="2"
                Content="保存并关闭"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="SaveAndCloseButton_Click" />
        </Grid>
    </Grid>
</Window>
