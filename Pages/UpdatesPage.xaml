<Page
    x:Class="WorkClosure.Pages.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="检查更新" Style="{StaticResource PageTitleTextStyle}" />

                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="打开仓库"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding OpenRepositoryCommand}" />
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="检查更新"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CheckForUpdatesCommand}" />
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <Border Style="{StaticResource HeroPanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="更新中心" Style="{StaticResource HeroTitleTextStyle}" />
                            <TextBlock Text="{Binding CurrentVersionText}" Style="{StaticResource HeroBodyTextStyle}" />
                            <TextBlock Text="{Binding CurrentChannelText}" Style="{StaticResource HeroBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfacePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="在线检查结果" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding LatestVersionText}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding LastCheckedText}" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding ReleaseNotesPreview}" Style="{StaticResource CaptionTextStyle}" />
                            <Button
                                HorizontalAlignment="Left"
                                Content="打开发布页"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenReleasesCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource SurfacePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="更新方式" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfacePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="当前版本亮点" Style="{StaticResource SectionTitleTextStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource SurfacePanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="版本历史" Style="{StaticResource SectionTitleTextStyle}" />
                    <ListView ItemsSource="{Binding VersionHistory}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:ReleaseHistoryItem">
                                <Border Margin="0,0,0,12" Style="{StaticResource SurfacePanelCompactStyle}">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Version}" FontSize="20" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Padding="10,4"
                                                Background="{ThemeResource AppAccentSoftBrush}"
                                                CornerRadius="999"
                                                VerticalAlignment="Top">
                                                <TextBlock
                                                    Foreground="{ThemeResource AppAccentStrongBrush}"
                                                    Text="{Binding TagText}" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Text="{Binding ReleaseDate}" Style="{StaticResource CaptionTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
