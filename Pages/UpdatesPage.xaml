<Page
    x:Class="WorkClosure.Pages.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock Text="检查更新" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="在这里查看当前安装版本、在线检查最新发布，并回看 WorkSolo 的版本历史。" Style="{StaticResource CaptionTextStyle}" />
                </StackPanel>

                <Button
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Content="打开仓库"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding OpenRepositoryCommand}" />
                <Button
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Content="检查更新"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding CheckForUpdatesCommand}" />
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <Border Style="{StaticResource HeroPanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="更新中心" Style="{StaticResource HeroTitleTextStyle}" />
                            <TextBlock Text="{Binding CurrentVersionText}" Style="{StaticResource HeroBodyTextStyle}" />
                            <TextBlock Text="{Binding CurrentChannelText}" Style="{StaticResource HeroBodyTextStyle}" />
                            <TextBlock Text="新版本发布后，直接在 GitHub Releases 下载压缩包覆盖程序即可，原有数据会保留在固定目录中。" Style="{StaticResource HeroBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfacePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="在线检查结果" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding LatestVersionText}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding LastCheckedText}" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="{Binding ReleaseNotesPreview}" Style="{StaticResource CaptionTextStyle}" />
                            <Button
                                HorizontalAlignment="Left"
                                Content="打开发布页"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenReleasesCommand}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource SurfacePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="更新方式" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="1. 在发布页下载最新压缩包" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="2. 解压后替换程序目录中的 WorkSolo.exe 和 AppLive" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="3. 保留 AppData\\Local\\WorkSolo 数据目录不动" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="4. 重新启动软件，历史数据会继续沿用" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfacePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="本次版本重点" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="• 固化版本号为 v1.0.1" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="• 新增检查更新 / 版本历史页面" Style="{StaticResource CaptionTextStyle}" />
                            <TextBlock Text="• 修正使用文档路径与版本显示链路" Style="{StaticResource CaptionTextStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource SurfacePanelStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="版本历史" Style="{StaticResource SectionTitleTextStyle}" />
                    <ListView ItemsSource="{Binding VersionHistory}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:ReleaseHistoryItem">
                                <Border Margin="0,0,0,12" Style="{StaticResource SurfacePanelCompactStyle}">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Version}" FontSize="20" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Padding="10,4"
                                                Background="{ThemeResource AppAccentSoftBrush}"
                                                CornerRadius="999"
                                                VerticalAlignment="Top">
                                                <TextBlock
                                                    Foreground="{ThemeResource AppAccentStrongBrush}"
                                                    Text="{Binding TagText}" />
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding Summary}" Style="{StaticResource CaptionTextStyle}" />
                                        <TextBlock Text="{Binding ReleaseDate}" Style="{StaticResource CaptionTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
