<Page
    x:Class="WorkClosure.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WorkClosure.Controls"
    xmlns:model="using:WorkClosure.Models">
    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20">
            <Border Style="{StaticResource HeroPanelStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="12">
                        <TextBlock Text="今天先把关键事项推进到闭环" Style="{StaticResource HeroTitleTextStyle}" />
                        <TextBlock
                            Text="这里适合快速补一条新事项，随后在事项清单中继续补充项目、日期和异常说明。"
                            Style="{StaticResource HeroBodyTextStyle}" />
                        <Grid ColumnSpacing="12" MaxWidth="720">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Header="快速新增"
                                PlaceholderText="例如：整理周会纪要并发送"
                                Text="{Binding QuickAddTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Content="加入清单"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding QuickAddCommand}" />
                        </Grid>
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Background="#1FFFFFFF"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="今日关注" Foreground="White" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="先处理已逾期，再清理今天到期事项，最后推进最近待办。" Style="{StaticResource HeroBodyTextStyle}" />
                            <TextBlock Text="建议顺序：逾期 -> 今日到期 -> 最近待推进" Style="{StaticResource HeroBodyTextStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard Grid.Column="0" Title="待处理事项" Value="{Binding OpenCount}" Subtitle="当前还未闭环的事项数量" />
                <controls:StatCard Grid.Column="1" Title="今天到期" Value="{Binding TodayDueCount}" Subtitle="今天需要重点关注的事项" />
                <controls:StatCard Grid.Column="2" Title="已逾期" Value="{Binding OverdueCount}" Subtitle="已经超过截止日期的事项" />
                <controls:StatCard Grid.Column="3" Title="本周完成" Value="{Binding CompletedThisWeekCount}" Subtitle="本周已闭环的事项数量" />
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="今天到期" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="优先清掉今天必须完成或确认状态的工作项。" Style="{StaticResource CaptionTextStyle}" />
                        <ListView ItemsSource="{Binding TodayDueTasks}" MaxHeight="380">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="model:WorkTaskItem">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextStyle}">
                                            <Run Text="{Binding ProjectName}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding StatusText}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding DueText}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SurfacePanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="已逾期" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="这些事项已经超时，建议先更新状态或补充异常原因。" Style="{StaticResource CaptionTextStyle}" />
                        <ListView ItemsSource="{Binding OverdueTasks}" MaxHeight="380">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="model:WorkTaskItem">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextStyle}">
                                            <Run Text="{Binding ProjectName}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding AnomalyText}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding DueText}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SurfacePanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="最近待推进" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="这里聚合近期仍未闭环的事项，方便持续追踪。" Style="{StaticResource CaptionTextStyle}" />
                        <ListView ItemsSource="{Binding RecentTasks}" MaxHeight="380">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="model:WorkTaskItem">
                                    <Grid Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextStyle}">
                                            <Run Text="{Binding ProjectName}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding StatusText}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding DueText}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
