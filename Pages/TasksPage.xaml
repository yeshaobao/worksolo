<Page
    x:Class="WorkClosure.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <Grid Padding="24" ColumnSpacing="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.75*" />
            <ColumnDefinition Width="1.05*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BackToPreviousButton"
                Grid.Column="0"
                VerticalAlignment="Top"
                Content="返回"
                Style="{StaticResource SecondaryButtonStyle}"
                Visibility="Collapsed"
                Click="BackToPreviousButton_Click" />

            <TextBlock
                Grid.Column="1"
                Text="事项清单"
                Style="{StaticResource PageTitleTextStyle}" />
        </Grid>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="14">
                <CommandBar DefaultLabelPosition="Right" HorizontalAlignment="Left">
                    <AppBarButton Icon="Add" Label="新建事项" Click="NewTaskDialogButton_Click" />
                    <AppBarButton Icon="OpenLocal" Label="打开事项" IsEnabled="{Binding HasSelectedTask}" Click="EditTaskDialogButton_Click" />
                    <AppBarSeparator />
                    <AppBarButton Icon="Play" Label="标记进行中" Command="{Binding StartTaskCommand}" />
                    <AppBarButton Icon="Accept" Label="标记完成" Command="{Binding CompleteTaskCommand}" />
                    <AppBarButton Icon="Cancel" Label="标记取消" Command="{Binding CancelTaskCommand}" />
                    <AppBarButton Icon="Delete" Label="删除" Command="{Binding DeleteTaskCommand}" />
                </CommandBar>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Grid.Column="0"
                        PlaceholderText="快速新增事项标题"
                        Text="{Binding QuickAddTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Grid.Column="1"
                        Content="加入清单"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding QuickAddCommand}" />
                    <TextBox
                        Grid.Column="2"
                        PlaceholderText="按标题、项目或进展内容搜索"
                        Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox
                        Grid.Column="3"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding ScopeOptions}"
                        PlaceholderText="范围"
                        SelectedValuePath="Value"
                        SelectedValue="{Binding SelectedScopeFilter, Mode=TwoWay}" />
                    <ComboBox
                        Grid.Column="4"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding ProjectFilters}"
                        PlaceholderText="项目"
                        SelectedValuePath="Id"
                        SelectedValue="{Binding SelectedProjectFilterId, Mode=TwoWay}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
            <ListView ItemsSource="{Binding FilteredTasks}" SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="model:WorkTaskItem">
                        <Border Margin="0,0,0,10" Style="{StaticResource SurfacePanelCompactStyle}">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextStyle}">
                                    <Run Text="项目：" />
                                    <Run Text="{Binding ProjectName}" />
                                    <Run Text="  |  状态：" />
                                    <Run Text="{Binding StatusText}" />
                                    <Run Text="  |  异常：" />
                                    <Run Text="{Binding AnomalyText}" />
                                </TextBlock>
                                <TextBlock Grid.Row="2" Style="{StaticResource CaptionTextStyle}">
                                    <Run Text="{Binding CreatedText}" />
                                    <Run Text="  |  " />
                                    <Run Text="{Binding DueText}" />
                                </TextBlock>
                                <TextBlock
                                    Grid.Row="3"
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding LatestProgressSummary}"
                                    TextWrapping="WrapWholeWords" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource SurfacePanelStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                <Grid Padding="0,4,0,0">
                    <StackPanel Visibility="{Binding EmptySelectionVisibility}" Spacing="12">
                        <TextBlock Text="事项预览" Style="{StaticResource SectionTitleTextStyle}" />
                        <Border Style="{StaticResource SurfacePanelCompactStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="当前未选择事项" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock
                                    Text="可先从左侧选中事项，或直接点击上方“新建事项”。"
                                    Style="{StaticResource CaptionTextStyle}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SelectedTaskVisibility}" Spacing="14">
                        <TextBlock Text="事项预览" Style="{StaticResource SectionTitleTextStyle}" />

                        <Border Style="{StaticResource SurfacePanelCompactStyle}">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="{Binding SelectedTask.Title}"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}">
                                    <Run Text="项目：" />
                                    <Run Text="{Binding SelectedTask.ProjectName}" />
                                    <Run Text="  |  状态：" />
                                    <Run Text="{Binding SelectedTask.StatusText}" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource CaptionTextStyle}">
                                    <Run Text="异常：" />
                                    <Run Text="{Binding SelectedTask.AnomalyText}" />
                                    <Run Text="  |  " />
                                    <Run Text="{Binding SelectedTask.DueText}" />
                                </TextBlock>
                                <TextBlock
                                    Style="{StaticResource CaptionTextStyle}"
                                    Text="{Binding SelectedTask.AnomalyNote}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <Button
                            Content="打开事项"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="EditTaskDialogButton_Click" />

                        <Border Style="{StaticResource SurfacePanelCompactStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="基本信息" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedTask.CreatedText}" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedTask.StartedText}" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedTask.CompletedText}" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedTask.LatestProgressSummary}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedTask.LatestIssueSummary}" TextWrapping="WrapWholeWords" />
                                <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding SelectedTask.LatestNextStepSummary}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <StackPanel Spacing="10">
                            <TextBlock Text="最近进展" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                Visibility="{Binding EmptyProgressVisibility}"
                                Text="当前还没有进展记录。"
                                Style="{StaticResource CaptionTextStyle}" />

                            <ItemsControl Visibility="{Binding ProgressEntriesVisibility}" ItemsSource="{Binding ProgressEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="model:TaskProgressEntry">
                                        <Border Margin="0,0,0,10" Style="{StaticResource SurfacePanelCompactStyle}">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock FontWeight="SemiBold" Text="{Binding EntryDateText}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Foreground="{ThemeResource WarningBrush}"
                                                        Text="{Binding FollowUpText}" />
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        Foreground="{ThemeResource AppAccentStrongBrush}"
                                                        Text="{Binding MilestoneText}" />
                                                </Grid>
                                                <TextBlock Text="{Binding ProgressText}" TextWrapping="WrapWholeWords" />
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{Binding IssueText}"
                                                    TextWrapping="WrapWholeWords" />
                                                <TextBlock
                                                    Style="{StaticResource CaptionTextStyle}"
                                                    Text="{Binding NextStepText}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
