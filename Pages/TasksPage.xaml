<Page
    x:Class="WorkClosure.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <Grid Padding="24" ColumnSpacing="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*" />
            <ColumnDefinition Width="1.1*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="6">
            <TextBlock Text="事项清单" Style="{StaticResource PageTitleTextStyle}" />
            <TextBlock Text="在这里集中处理新增、编辑、状态变更和删除，让每一条事项都能从记录走到闭环。" Style="{StaticResource CaptionTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="14">
                <CommandBar DefaultLabelPosition="Right">
                    <AppBarButton Label="新建" Icon="Add" Command="{Binding NewTaskCommand}" />
                    <AppBarButton Label="开始" Icon="Play" Command="{Binding StartTaskCommand}" />
                    <AppBarButton Label="完成" Icon="Accept" Command="{Binding CompleteTaskCommand}" />
                    <AppBarButton Label="取消" Icon="Cancel" Command="{Binding CancelTaskCommand}" />
                    <AppBarButton Label="删除" Icon="Delete" Command="{Binding DeleteTaskCommand}" />
                </CommandBar>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Header="快速新增"
                        PlaceholderText="先输入标题，默认截止日期为今天"
                        Text="{Binding QuickAddTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox
                        Grid.Column="1"
                        Header="范围"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding ScopeOptions}"
                        SelectedValuePath="Value"
                        SelectedValue="{Binding SelectedScopeFilter, Mode=TwoWay}" />
                    <Button
                        Grid.Column="2"
                        VerticalAlignment="Bottom"
                        Content="加入清单"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding QuickAddCommand}" />
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Grid.Column="0"
                        Header="搜索"
                        PlaceholderText="按标题搜索事项"
                        Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox
                        Grid.Column="1"
                        Header="项目"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding ProjectFilters}"
                        SelectedValuePath="Id"
                        SelectedValue="{Binding SelectedProjectFilterId, Mode=TwoWay}" />
                </Grid>

                <TextBlock Text="单击左侧事项即可进入编辑；删除会直接移除当前事项。" Style="{StaticResource CaptionTextStyle}" />

                <ListView
                    Height="560"
                    ItemsSource="{Binding FilteredTasks}"
                    SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:WorkTaskItem">
                            <Border Style="{StaticResource SurfacePanelCompactStyle}" Margin="0,0,0,10">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextStyle}">
                                        <Run Text="项目：" />
                                        <Run Text="{Binding ProjectName}" />
                                        <Run Text="  ·  状态：" />
                                        <Run Text="{Binding StatusText}" />
                                        <Run Text="  ·  异常：" />
                                        <Run Text="{Binding AnomalyText}" />
                                    </TextBlock>
                                    <TextBlock Grid.Row="2" Style="{StaticResource CaptionTextStyle}">
                                        <Run Text="{Binding CreatedText}" />
                                        <Run Text="  ·  " />
                                        <Run Text="{Binding DueText}" />
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Style="{StaticResource SurfacePanelStyle}">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Editor.HeaderText}" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Text="右侧用于补充标题、项目、日期和异常说明。新建事项时，截止日期默认就是今天。" Style="{StaticResource CaptionTextStyle}" />
                    <TextBox Header="标题" Text="{Binding Editor.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox
                        Header="项目"
                        DisplayMemberPath="Name"
                        ItemsSource="{Binding Editor.ProjectOptions}"
                        SelectedValuePath="Id"
                        SelectedValue="{Binding Editor.SelectedProjectId, Mode=TwoWay}" />
                    <ComboBox
                        Header="主状态"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding Editor.StatusOptions}"
                        SelectedValuePath="Value"
                        SelectedValue="{Binding Editor.SelectedStatusValue, Mode=TwoWay}" />
                    <ComboBox
                        Header="异常标记"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding Editor.AnomalyOptions}"
                        SelectedValuePath="Value"
                        SelectedValue="{Binding Editor.SelectedAnomalyValue, Mode=TwoWay}" />
                    <CalendarDatePicker Header="截止日期" Date="{Binding Editor.DueDate, Mode=TwoWay}" />
                    <TextBox
                        Header="异常说明"
                        AcceptsReturn="True"
                        MinHeight="90"
                        Text="{Binding Editor.AnomalyNote, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Border Style="{StaticResource SurfacePanelCompactStyle}">
                        <StackPanel Spacing="6">
                            <TextBlock Text="时间信息" FontWeight="SemiBold" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Editor.CreatedText}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Editor.StartedText}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding Editor.CompletedText}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="保存事项" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveTaskCommand}" />
                        <Button Content="新建空白" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewTaskCommand}" />
                        <Button Content="删除事项" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteTaskCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
