<Page
    x:Class="WorkClosure.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <Grid Padding="24" ColumnSpacing="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="6">
                <TextBlock Text="项目分类" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="项目用于组织事项和后续复盘。这里支持新增、编辑、停用和删除，删除项目时会将关联事项转为未分类。" Style="{StaticResource CaptionTextStyle}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Content="新建项目"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding NewProjectCommand}" />
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="项目概览" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="选中左侧项目后，右侧即可直接编辑；未分类是系统聚合项，不能单独删除。" Style="{StaticResource CaptionTextStyle}" />
                <ListView ItemsSource="{Binding ProjectSummaries}" SelectedItem="{Binding SelectedSummary, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:ProjectProgressSummary">
                            <Border Style="{StaticResource SurfacePanelCompactStyle}" Margin="0,0,0,10">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}">
                                        <Run Text="总数：" />
                                        <Run Text="{Binding Total}" />
                                        <Run Text="  ·  已完成：" />
                                        <Run Text="{Binding Completed}" />
                                        <Run Text="  ·  未闭环：" />
                                        <Run Text="{Binding Open}" />
                                        <Run Text="  ·  已逾期：" />
                                        <Run Text="{Binding Overdue}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="编辑项目" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="新建项目时只填名称也可以保存。删除项目后，原来归属该项目的事项会自动转为未分类。" Style="{StaticResource CaptionTextStyle}" />
                <TextBox Header="名称" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Header="说明"
                    AcceptsReturn="True"
                    MinHeight="120"
                    Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ToggleSwitch Header="启用状态" IsOn="{Binding IsActive, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="保存项目" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveProjectCommand}" />
                    <Button Content="新建空白" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewProjectCommand}" />
                    <Button Content="删除项目" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteProjectCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
