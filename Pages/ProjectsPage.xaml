<Page
    x:Class="WorkClosure.Pages.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:WorkClosure.Models">
    <Grid Padding="24" ColumnSpacing="16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="项目分类" Style="{StaticResource PageTitleTextStyle}" />
            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Content="新建项目"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding NewProjectCommand}" />
        </Grid>

        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="项目概览" Style="{StaticResource SectionTitleTextStyle}" />
                <ListView ItemsSource="{Binding ProjectSummaries}" SelectedItem="{Binding SelectedSummary, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:ProjectProgressSummary">
                            <Border Margin="0,0,0,10" Style="{StaticResource SurfacePanelCompactStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{Binding ProjectName}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource CaptionTextStyle}">
                                        <Run Text="总数：" />
                                        <Run Text="{Binding Total}" />
                                        <Run Text="  |  已完成：" />
                                        <Run Text="{Binding Completed}" />
                                        <Run Text="  |  未闭环：" />
                                        <Run Text="{Binding Open}" />
                                        <Run Text="  |  已超期：" />
                                        <Run Text="{Binding Overdue}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SurfacePanelStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="{Binding EditorTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBox Header="名称" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Header="说明"
                    AcceptsReturn="True"
                    MinHeight="120"
                    Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ToggleSwitch Header="启用状态" IsOn="{Binding IsActive, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="{Binding SaveButtonText}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveProjectCommand}" />
                    <Button Content="新建空白" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding NewProjectCommand}" />
                    <Button Content="删除项目" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteProjectCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
