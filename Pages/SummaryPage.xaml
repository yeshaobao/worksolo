<Page
    x:Class="WorkClosure.Pages.SummaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WorkClosure.Controls"
    xmlns:model="using:WorkClosure.Models">
    <Grid Padding="20" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0">
            <StackPanel Spacing="20">
                <TextBlock Text="总结复盘" Style="{StaticResource PageTitleTextStyle}" />

                <Border Style="{StaticResource SurfacePanelStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox
                            Width="180"
                            Header="统计周期"
                            DisplayMemberPath="Label"
                            ItemsSource="{Binding PeriodOptions}"
                            SelectedValuePath="Value"
                            SelectedValue="{Binding SelectedPeriod, Mode=TwoWay}" />
                        <Button VerticalAlignment="Bottom" Content="上一周期" Command="{Binding PreviousPeriodCommand}" />
                        <Button VerticalAlignment="Bottom" Content="下一周期" Command="{Binding NextPeriodCommand}" />
                        <TextBlock VerticalAlignment="Bottom" Text="{Binding RangeTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="0" Click="CreatedCard_Click">
                        <controls:StatCard Title="新增事项" Value="{Binding CreatedCount}" Subtitle="所选周期内新增的事项数量" />
                    </Button>
                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0" Click="CompletedCard_Click">
                        <controls:StatCard Title="完成事项" Value="{Binding CompletedCount}" Subtitle="所选周期内已闭环完成的事项" />
                    </Button>
                    <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0" Click="OpenCard_Click">
                        <controls:StatCard Title="当前未闭环" Value="{Binding OpenCount}" Subtitle="当前仍在推进中的事项数量" />
                    </Button>
                    <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="0" Click="OverdueCard_Click">
                        <controls:StatCard Title="当前已超期" Value="{Binding OverdueCount}" Subtitle="当前开放事项中已超期的数量" />
                    </Button>
                </Grid>

                <Border Style="{StaticResource SurfacePanelStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="项目快照" Style="{StaticResource SectionTitleTextStyle}" />
                        <ListView
                            ItemsSource="{Binding ProjectSummaries}"
                            IsItemClickEnabled="True"
                            ItemClick="ProjectSummaries_ItemClick"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="model:ProjectProgressSummary">
                                    <Border Margin="0,0,0,10" Style="{StaticResource SurfacePanelCompactStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
                                            <TextBlock Style="{StaticResource CaptionTextStyle}">
                                                <Run Text="总数：" />
                                                <Run Text="{Binding Total}" />
                                                <Run Text=" | 已完成：" />
                                                <Run Text="{Binding Completed}" />
                                                <Run Text=" | 未闭环：" />
                                                <Run Text="{Binding Open}" />
                                                <Run Text=" | 已超期：" />
                                                <Run Text="{Binding Overdue}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Column="1"
            Width="400"
            Style="{StaticResource SurfacePanelStyle}"
            Visibility="{Binding InspectorVisibility}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding InspectorTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                    <Button Grid.Column="1" Content="返回" Command="{Binding CloseInspectorCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>

                <Grid Grid.Row="2">
                    <ListView ItemsSource="{Binding InspectorTasks}" Visibility="{Binding InspectorTasksVisibility}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:WorkTaskItem">
                                <Border Margin="0,0,0,10" Style="{StaticResource SurfacePanelCompactStyle}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Style="{StaticResource CaptionTextStyle}">
                                            <Run Text="{Binding ProjectName}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding StatusText}" />
                                            <Run Text=" | " />
                                            <Run Text="{Binding DueText}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding LatestProgressSummary}" />
                                        <Button
                                            HorizontalAlignment="Left"
                                            Click="InspectorTaskButton_Click"
                                            Content="进入事项清单"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Tag="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border
                        Padding="20"
                        Background="{ThemeResource AppSurfaceAltBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Visibility="{Binding InspectorEmptyVisibility}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding InspectorEmptyText}" Style="{StaticResource CaptionTextStyle}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
